<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SorweStore" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- Hide system splash screen icon -->
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="31">@android:color/transparent</item>
        
        <!-- Match window background to app background for seamless start -->
        <item name="android:windowBackground">@color/light_background</item>
        
        <!-- Disable system preview window (remove 1s blank screen) -->
        <item name="android:windowDisablePreview">true</item>
    </style>
</resources>
